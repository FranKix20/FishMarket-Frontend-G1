# ===========================================================================
# FishMarket Frontend (G1) — variables de entorno. Copia a `.env`.
# ===========================================================================

# BFF del ecosistema (auth/catálogo/carrito/pedidos/etc.).
VITE_API_BASE_URL=https://bff-mock-g1.vercel.app

# --- Perfil / cuenta (servicio de Identidad G2, directo) -------------------
# Se usa solo en "Mi cuenta" para /users/me y cambiar contraseña. Si no se
# define, usa el deploy público de G2.
VITE_IDENTITY_URL=https://auth-minimarket-cloud.onrender.com

# --- Recuperación de contraseña (Supabase, flujo nativo) -------------------
# Deben apuntar al MISMO proyecto Supabase donde G2 guarda los usuarios.
# Son claves PÚBLICAS (la anon key está pensada para el frontend). NO uses aquí
# la service_role. Supabase -> Project Settings -> API.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
